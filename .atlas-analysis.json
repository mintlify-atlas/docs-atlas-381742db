  "keyFeatures": [
    "Multiple RAG architectures: Simple Semantic, Hybrid (BM25+Semantic), HyDE, Query Rewriter, and PageIndex",
    "RAGAS evaluation framework with faithfulness, answer relevancy, context precision, and context recall metrics",
    "Multi-model benchmarking with GPT-4o default, extensible to GPT-5, GPT-5.2, MediPhi, and MedGemma",
    "ChromaDB vector store with OpenAI embeddings for semantic search",
    "LangChain-based pipeline for retrieval and generation",
    "Comprehensive evaluation results with JSON output and timestamp tracking"
  ],
  "publicApiSurface": [
    "query_for_evaluation(question, model_name) - Simple Semantic RAG",
    "query_for_evaluation(question, model_name) - Hybrid RAG with BM25",
    "query_for_evaluation(question, model_name) - Hybrid RRF RAG",
    "query_for_evaluation(question, model_name) - HyDE RAG",
    "query_for_evaluation(question, model_name) - Query Rewriter RAG",
    "query_for_evaluation(question, model_name) - PageIndex RAG",
    "RAGASEvaluator.evaluate_rag(rag_type, model_name) - Evaluate single RAG",
    "RAGASEvaluator.evaluate_all_models_single_rag(rag_type) - Multi-model evaluation",
    "RAGASEvaluator.evaluate_all_models_all_rags() - Comprehensive benchmark",
    "create_llm(model_config) - Create LLM instance from config",
    "get_model_identity(model) - Get model identifier",
    "resolve_total_cost(usage, model) - Calculate API costs"
  ]
